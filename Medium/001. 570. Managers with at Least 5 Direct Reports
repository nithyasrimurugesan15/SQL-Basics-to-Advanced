without join (using in) : 

select name from employee  
where id in (
    select managerid from employee 
    where managerid is not null 
    group by managerid
    having count(managerid) >= 5
);

with join :

SELECT e.name
FROM Employee e
JOIN (
    SELECT managerId
    FROM Employee
   GROUP BY managerId
    HAVING COUNT(*) >= 5
) m
ON e.id = m.managerId;
